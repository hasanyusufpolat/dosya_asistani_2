{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "pip install --upgrade pip setuptools wheel && pip install --only-binary pandas pandas==2.0.3 && pip install -r requirements.txt"
    },
    "deploy": {
        "startCommand": "python bot.py",
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    },
    "env": {
        "PYTHON_VERSION": "3.11.9",
        "PIP_USE_PEP517": "0",
        "PIP_NO_BUILD_ISOLATION": "0"
    }
}
