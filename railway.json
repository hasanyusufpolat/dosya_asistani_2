{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "pip install --upgrade pip setuptools wheel && pip install -r requirements.txt",
        "watchPatterns": [
            "requirements.txt",
            "runtime.txt"
        ]
    },
    "deploy": {
        "startCommand": "python bot.py",
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    },
    "env": {
        "PYTHON_VERSION": "3.11.9",
        "PIP_USE_PEP517": "1"
    }
}
